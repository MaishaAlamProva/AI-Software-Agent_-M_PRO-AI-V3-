l,"max_height":null,"max_width":null,"min_height":null,"min_width":null,"object_fit":null,"object_position":null,"order":null,"overflow":null,"overflow_x":null,"overflow_y":null,"padding":null,"right":null,"top":null,"visibility":null,"width":null}},"d3da1a97d8f343eca5be43b1bfdb4d2f":{"model_module":"@jupyter-widgets/controls","model_name":"ProgressStyleModel","model_module_version":"1.5.0","state":{"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"ProgressStyleModel","_view_count":null,"_view_module":"@jupyter-widgets/base","_view_module_version":"1.2.0","_view_name":"StyleView","bar_color":null,"description_width":""}},"8bbdf9a78a80403b8e318de9d61cb7e5":{"model_module":"@jupyter-widgets/base","model_name":"LayoutModel","model_module_version":"1.2.0","state":{"_model_module":"@jupyter-widgets/base","_model_module_version":"1.2.0","_model_name":"LayoutModel","_view_count":null,"_view_module":"@jupyter-widgets/base","_view_module_version":"1.2.0","_view_name":"LayoutView","align_content":null,"align_items":null,"align_self":null,"border":null,"bottom":null,"display":null,"flex":null,"flex_flow":null,"grid_area":null,"grid_auto_columns":null,"grid_auto_flow":null,"grid_auto_rows":null,"grid_column":null,"grid_gap":null,"grid_row":null,"grid_template_areas":null,"grid_template_columns":null,"grid_template_rows":null,"height":null,"justify_content":null,"justify_items":null,"left":null,"margin":null,"max_height":null,"max_width":null,"min_height":null,"min_width":null,"object_fit":null,"object_position":null,"order":null,"overflow":null,"overflow_x":null,"overflow_y":null,"padding":null,"right":null,"top":null,"visibility":null,"width":null}},"1e4c57c76b2942fba63c84fa05199059":{"model_module":"@jupyter-widgets/controls","model_name":"DescriptionStyleModel","model_module_version":"1.5.0","state":{"_model_module":"@jupyter-widgets/controls","_model_module_version":"1.5.0","_model_name":"DescriptionStyleModel","_view_count":null,"_view_module":"@jupyter-widgets/base","_view_module_version":"1.2.0","_view_name":"StyleView","description_width":""}}}}},"cells":[{"cell_type":"code","source":["# =========================================================\n","# PROVA AI V3 — PROFESSIONAL TERMINAL UI EDITION\n","# =========================================================\n","\n","!pip install -q -U \\\n","langchain \\\n","langchain-community \\\n","langchain-core \\\n","langchain-huggingface \\\n","langchain-groq \\\n","faiss-cpu \\\n","sentence-transformers \\\n","rich\n","\n","# =========================================================\n","# IMPORTS\n","# =========================================================\n","\n","import os\n","from getpass import getpass\n","import faiss\n","\n","from rich.console import Console\n","from rich.panel import Panel\n","from rich.table import Table\n","from rich import box\n","from rich.markdown import Markdown\n","\n","from langchain_groq import ChatGroq\n","from langchain_core.prompts import ChatPromptTemplate\n","from langchain_community.vectorstores import FAISS\n","from langchain_community.docstore.in_memory import InMemoryDocstore\n","from langchain_huggingface import HuggingFaceEmbeddings\n","\n","# =========================================================\n","# UI CONSOLE\n","# =========================================================\n","\n","console = Console()\n","\n","# =========================================================\n","# API KEY\n","# =========================================================\n","\n","os.environ[\"GROQ_API_KEY\"] = getpass(\"Enter GROQ API Key: \")\n","\n","# =========================================================\n","# EMBEDDING MODEL\n","# =========================================================\n","\n","embedding_model = HuggingFaceEmbeddings(\n","    model_name=\"sentence-transformers/all-MiniLM-L6-v2\"\n",")\n","\n","# =========================================================\n","# MEMORY\n","# =========================================================\n","\n","MEMORY_PATH = \"prova_memory\"\n","\n","if os.path.exists(MEMORY_PATH):\n","\n","    console.print(Panel(\"[green]Loading Existing Memory[/green]\", style=\"green\"))\n","\n","    vectorstore = FAISS.load_local(\n","        MEMORY_PATH,\n","        embedding_model,\n","        allow_dangerous_deserialization=True\n","    )\n","\n","else:\n","\n","    console.print(Panel(\"[yellow]Creating New Memory[/yellow]\", style=\"yellow\"))\n","\n","    dimension = 384\n","    index = faiss.IndexFlatL2(dimension)\n","\n","    vectorstore = FAISS(\n","        embedding_function=embedding_model,\n","        index=index,\n","        docstore=InMemoryDocstore(),\n","        index_to_docstore_id={}\n","    )\n","\n","    initial_memories = [\n","        \"Project standard: use snake_case naming convention.\",\n","        \"Backend framework must always be FastAPI.\",\n","        \"Use async endpoints whenever possible.\",\n","        \"All APIs must include proper error handling.\",\n","        \"Avoid blocking operations in production code.\",\n","        \"Database layer must use repository pattern.\"\n","    ]\n","\n","    vectorstore.add_texts(initial_memories)\n","    vectorstore.save_local(MEMORY_PATH)\n","\n","# =========================================================\n","# RETRIEVER\n","# =========================================================\n","\n","retriever = vectorstore.as_retriever(search_kwargs={\"k\": 4})\n","\n","# =========================================================\n","# LLM\n","# =========================================================\n","\n","llm = ChatGroq(\n","    model=\"llama-3.3-70b-versatile\",\n","    temperature=0,\n","    max_tokens=4096\n","\n","\n","# =========================================================\n","# PROMPT\n","# =========================================================\n","\n","prompt = ChatPromptTemplate.from_template(\"\"\"\n","You are M_PRO AI V3,\n","an elite AI Software Architect.\n","\n","PROJECT MEMORY:\n","{memory}\n","\n","USER REQUEST:\n","{input}\n","\n","Give:\n","- code review\n","- issues\n","- improvements\n","- production suggestions\n","\"\"\")\n","\n","# =========================================================\n","# MEMORY RETRIEVAL\n","# =========================================================\n","\n","def retrieve_memory(user_input):\n","    docs = retriever.invoke(user_input)\n","    return \"\\n\".join([d.page_content for d in docs])\n","\n","# =========================================================\n","#  AI OUTPUT\n","# =========================================================\n","\n","def architect(user_input):\n","\n","    memory = retrieve_memory(user_input)\n","\n","    response = llm.invoke(\n","        prompt.format(memory=memory, input=user_input)\n","    )\n","\n","    console.print()\n","\n","    console.print(\n","        Panel.fit(\n","            \"[bold cyan]M_PRO AI V3[/bold cyan]\\n\"\n","            \"[green]AI Coding Architect Response[/green]\",\n","            border_style=\"cyan\"\n","        )\n","    )\n","\n","    console.print(\n","        Panel(\n","            Markdown(response.content),\n","            title=\"[yellow]AI REVIEW[/yellow]\",\n","            border_style=\"yellow\",\n","            box=box.ROUNDED\n","        )\n","    )\n","\n","# =========================================================\n","# ADD MEMORY (UI)\n","# =========================================================\n","\n","def add_memory(text):\n","\n","    vectorstore.add_texts([text])\n","    vectorstore.save_local(MEMORY_PATH)\n","\n","    console.print(\n","        Panel.fit(\n","            f\"[bold green]MEMORY SAVED[/bold green]\\n\\n{text}\",\n","            border_style=\"green\"\n","        )\n","    )\n","\n","# =========================================================\n","# SHOW MEMORY (TABLE UI)\n","# =========================================================\n","\n","def show_memory():\n","\n","    docs = vectorstore.similarity_search(\"project rules\", k=20)\n","\n","    table = Table(\n","        title=\"PROVA AI V3 MEMORY\",\n","        box=box.DOUBLE_EDGE,\n","        border_style=\"magenta\"\n","    )\n","\n","    table.add_column(\"#\", style=\"cyan\")\n","    table.add_column(\"Stored Rules\", style=\"white\")\n","\n","    seen = set()\n","    i = 1\n","\n","    for d in docs:\n","        if d.page_content not in seen:\n","            seen.add(d.page_content)\n","            table.add_row(str(i), d.page_content)\n","            i += 1\n","\n","    console.print(table)\n","\n","# =========================================================\n","# DEMO MEMORY\n","# =========================================================\n","\n","add_memory(\"Use JWT authentication for protected APIs.\")\n","add_memory(\"Never expose database credentials in source code.\")\n","\n","# =========================================================\n","# SAMPLE RUN\n","# =========================================================\n","\n","sample_code = \"\"\"\n","from flask import Flask\n","\n","app = Flask(__name__)\n","\n","@app.route(\"/users\")\n","def GetUsers():\n","    data = slow_database_call()\n","    return data\n","\"\"\"\n","\n","architect(f\"Review this code:\\n{sample_code}\")\n","\n","architect(\"What backend framework should we use?\")\n","\n","# =========================================================\n","# MEMORY VIEW\n","# =========================================================\n","\n","show_memory()\n","\n","# =========================================================\n","# CHAT MODE\n","# =========================================================\n","\n","console.print(\n","    Panel.fit(\n","        \"[bold green]M_PRO AI V3 READY[/bold green]\\n\"\n","        \"Type 'exit' to quit\\n\"\n","        \"Type 'remember: text' to store memory\",\n","        border_style=\"green\"\n","    )\n",")\n","\n","while True:\n","\n","    user_input = input(\"\\nYou: \")\n","\n","    if user_input.lower() == \"exit\":\n","        console.print(\"[red]Session Ended[/red]\")\n","        break\n","\n","    elif user_input.startswith(\"remember:\"):\n","        add_memory(user_input.replace(\"remember:\", \"\").strip())\n","\n","    else:\n","        architect(user_input)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"referenced_widgets":["78310fead86c460e9be38e0e7b3fe9d4","ade3db87e5314790834cbbe6a2cca8a8","d6b0aef0d1dc4f59980444f0054ac560","25b48d39c653491ea4579782753cc127","9d4c3e1e349b4511b681f365db0a48d4","f39fd959c7d64a66a6e07928d96ade66","3a4d932569404573a8283a37d550d7a7","6ac0aecb5bec4426afac5d953ff99b0d","d3da1a97d8f343eca5be43b1bfdb4d2f","8bbdf9a78a80403b8e318de9d61cb7e5","1e4c57c76b2942fba63c84fa05199059"]},"id":"CW8kzMZjbeNE","executionInfo":{"status":"error","timestamp":1778343231186,"user_tz":-360,"elapsed":581236,"user":{"displayName":"Maisha Alam Prova","userId":"14263348759053733869"}},"outputId":"de5598de-60b7-4452-baf5-dd213c491b9a"},"execution_count":2,"outputs":[{"name":"stdout","output_type":"stream","text":["Enter GROQ API Key: ··········\n"]},{"output_type":"display_data","data":{"text/plain":["Loading weights:   0%|          | 0/103 [00:00<?, ?it/s]"],"application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"78310fead86c460e9be38e0e7b3fe9d4"}},"metadata":{}},{"output_type":"stream","name":"stderr","text":["BertModel LOAD REPORT from: sentence-transformers/all-MiniLM-L6-v2\n","Key                     | Status     |  | \n","------------------------+------------+--+-\n","embeddings.position_ids | UNEXPECTED |  | \n","\n","Notes:\n","- UNEXPECTED\t:can be ignored when loading from different task/architecture; not ok if you expect identical arch.\n"]},{"output_type":"display_data","data":{"text/plain":["\u001b[32m╭─────────────────────────────────────────────────────────────────────────────────────────────────────────────────╮\u001b[0m\n","\u001b[32m│\u001b[0m\u0